#!/bin/sh
export JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
# Maven Wrapper Script
# This script downloads Maven if needed and runs it
# Usage: ./mvnw clean install

# Determine the directory of this script
DIRNAME=$(dirname "$0")
MAVEN_PROJECTBASEDIR=$(cd "$DIRNAME" && pwd)

# Maven Wrapper Properties
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

# Read distribution URL from properties
if [ -r "$MAVEN_WRAPPER_PROPERTIES" ]; then
    distributionUrl=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

MAVEN_HOME="$HOME/.m2/wrapper/dists/$(basename "$distributionUrl" .zip)"

# Download Maven if not present
if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven..."
    mkdir -p "$MAVEN_HOME"
    if command -v curl > /dev/null 2>&1; then
        curl -sL "$distributionUrl" -o /tmp/maven.zip
    elif command -v wget > /dev/null 2>&1; then
        wget -q "$distributionUrl" -O /tmp/maven.zip
    else
        echo "Error: curl or wget required"
        exit 1
    fi
    unzip -q /tmp/maven.zip -d "$MAVEN_HOME"
    rm /tmp/maven.zip
fi

# Find Maven executable
MAVEN_EXEC=$(find "$MAVEN_HOME" -name "mvn" -path "*/bin/mvn" | head -1)

if [ -z "$MAVEN_EXEC" ]; then
    echo "Error: Maven executable not found"
    exit 1
fi

# Execute Maven
exec "$MAVEN_EXEC" "$@"
