KEYCLOAK_ISSUER_URI=https://<your-skycloak-id>.us.skycloak.io/realms/sso-realm
KEYCLOAK_JWKS_URI=https://<your-skycloak-id>.us.skycloak.io/realms/sso-realm/protocol/openid-connect/certs
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Keycloak OAuth2 Client Settings
KEYCLOAK_CLIENT_ID=inventory-backend
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret

# Database Configuration (Supabase PostgreSQL via IPv4 Pooler)
DB_URL=jdbc:postgresql://<your-supabase-db>.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.<your-db-user>
DB_PASSWORD=your_db_password
